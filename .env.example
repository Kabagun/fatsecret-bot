# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-me

# Optional but recommended. If empty, the first two /start users are registered.
# Comma-separated Telegram numeric user IDs.
TELEGRAM_ALLOWED_USER_IDS=

# Runtime SQLite location. Keep it under temp/ so secrets/runtime state stay uncommitted.
FATSECRET_BOT_DB_PATH=temp/state/fatsecret_bot.sqlite3

# FatSecret app/device defaults from the captured Android app.
FATSECRET_APP_VERSION=11.5.0.4
FATSECRET_LANG=ru
FATSECRET_MKT=BY
FATSECRET_DEVICE=6
FATSECRET_BUILD_SDK=30
FATSECRET_BUILD_API=11
FATSECRET_BUILD_MODEL=NE2211
FATSECRET_BUILD_RESOLUTION=1920x1080
FATSECRET_DEVICE_IDENTIFIER=NE2211

# Optional static app Authorization header observed in the mobile app login request.
# Leave empty if login works without it. Do not commit a real value.
FATSECRET_AUTHORIZATION=
FATSECRET_C_DESC=
FATSECRET_USER_AGENT=FatSecretBot/0.1

# Account 1
FATSECRET_ACCOUNT_1_KEY=account1
FATSECRET_ACCOUNT_1_LABEL=Account 1
FATSECRET_ACCOUNT_1_USERNAME=
FATSECRET_ACCOUNT_1_PASSWORD=

# Account 2
FATSECRET_ACCOUNT_2_KEY=account2
FATSECRET_ACCOUNT_2_LABEL=Account 2
FATSECRET_ACCOUNT_2_USERNAME=
FATSECRET_ACCOUNT_2_PASSWORD=
